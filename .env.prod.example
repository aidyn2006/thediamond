# Copy to .env and fill in. Used by docker-compose.prod.yml.

# Domain that points to this VPS (Caddy issues TLS for it)
DOMAIN=thediamond.example.com

# PostgreSQL
POSTGRES_DB=thediamond
POSTGRES_USER=thediamond
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Backend JWT signing secret (>= 32 chars). Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_secret

# Auth.js session secret. Generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_authjs_secret

# Optional email (leave empty to log emails to the backend console)
RESEND_API_KEY=
MAIL_FROM=TheDiamond <onboarding@resend.dev>
