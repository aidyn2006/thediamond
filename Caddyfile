# Auto-HTTPS via Let's Encrypt. DOMAIN must point (A/AAAA) to this VPS,
# and ports 80/443 must be open.
{$DOMAIN} {
	encode gzip

	# avatar files are served by the backend
	handle /uploads/* {
		reverse_proxy backend:8080
	}

	# everything else (site + Auth.js API) -> Next.js frontend
	handle {
		reverse_proxy frontend:3000
	}
}
